# =============================================================================
# ad-generator .env
# =============================================================================
# Copy to .env and fill in real value

# --- LLM provider (model-agnostic via LiteLLM) -----------------------------
# Supported: claude | openai | gemini | mistral | groq | ollama
LLM_PROVIDER=claude
LLM_MODEL_CLAUDE=claude-opus-4-7
LLM_MODEL_OPENAI=gpt-5
LLM_MODEL_GEMINI=gemini-2-flash
LLM_MODEL_OLLAMA=llama3.1:70b

# API keys (LiteLLM reads the one matching active provider)
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=...

# Use cheaper model for low-stakes skills (parser, validator)
LLM_MODEL_CHEAP=claude-haiku-4-5-20251001

# --- Vector store ---------------------------------------------------------
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=ad-styles

# Embedding model (also via LiteLLM)
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIM=3072

# --- Image generation -----------------------------------------------------
IMAGE_GEN_PROVIDER=nano-banana-2
NANO_BANANA_API_KEY=
OPENAI_IMAGE_API_KEY=

# --- Output / assembler ---------------------------------------------------
# Entregável final: PNG (default) ou JPEG. HTML/Figma só pra debug/legacy.
ASSEMBLER=png            # png | jpeg | html | figma (stub)
OUTPUT_FORMAT=png        # png | jpeg | both
JPEG_QUALITY=92

# Figma (legacy / future):
FIGMA_FILE_KEY=pzU3E4A2tXyA4ZDYbYQekP
FIGMA_PAGE_NAME=AI-Generated Ads
FIGMA_TOKEN=

# --- Knowledge paths ------------------------------------------------------
BRAND_KNOWLEDGE_PATH=../../brand-knowledge

# --- Behavior -------------------------------------------------------------
DEFAULT_TEMPERATURE=0
LOG_LEVEL=INFO
ARTIFACTS_DIR=./artifacts

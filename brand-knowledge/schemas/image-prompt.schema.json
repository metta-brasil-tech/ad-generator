{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://metta.brand-knowledge/image-prompt.schema.json",
  "title": "Image Prompt — output do 04-image-prompt-engineer",
  "type": "object",
  "required": ["skip"],
  "properties": {
    "skip": {
      "type": "boolean",
      "description": "true se o estilo não usa imagem (ex: Estilo C tipografia pura)"
    },
    "skip_reason": { "type": "string" },
    "prompts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["slot_name", "prompt"],
        "properties": {
          "slot_name": { "type": "string" },
          "prompt": { "type": "string", "minLength": 50 },
          "negative_prompt": { "type": "string" },
          "aspect_ratio": {
            "type": "string",
            "enum": ["9:16", "16:9", "1:1", "4:5", "5:4", "3:2", "2:3", "free"]
          },
          "reference_images": {
            "type": "array",
            "items": { "type": "string", "format": "uri" }
          },
          "model_hint": {
            "type": "string",
            "enum": ["nano-banana-2", "gpt-image-1", "flux", "midjourney", "dall-e-3"]
          },
          "iteration_strategy": {
            "type": "object",
            "properties": {
              "max_attempts": { "type": "integer", "minimum": 1, "maximum": 5 },
              "fallback_prompts": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          },
          "metadata": {
            "type": "object",
            "properties": {
              "style_id": { "type": "string" },
              "audience": { "type": "string" },
              "mood_chosen": { "type": "string" }
            }
          }
        }
      }
    }
  }
}

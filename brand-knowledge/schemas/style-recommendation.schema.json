{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://metta.brand-knowledge/style-recommendation.schema.json",
  "title": "Style Recommendation — output do 02-style-selector",
  "type": "object",
  "required": ["recommended", "auto_select_recommendation"],
  "properties": {
    "recommended": {
      "type": "array",
      "minItems": 1,
      "maxItems": 3,
      "items": {
        "type": "object",
        "required": ["rank", "model_id", "yaml_path", "score", "rationale"],
        "properties": {
          "rank": { "type": "integer", "minimum": 1, "maximum": 3 },
          "model_id": { "type": "string" },
          "yaml_path": { "type": "string" },
          "score": { "type": "number", "minimum": 0, "maximum": 1 },
          "rationale": { "type": "string", "minLength": 20 },
          "tradeoffs": { "type": "string" }
        }
      }
    },
    "rejected_with_explanation": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "model_id": { "type": "string" },
          "reason": { "type": "string" }
        }
      }
    },
    "auto_select_recommendation": {
      "type": "string",
      "enum": ["rank_1", "ask_human"]
    },
    "campaign_context_note": { "type": ["string", "null"] }
  }
}
